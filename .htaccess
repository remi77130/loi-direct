<IfModule mod_negotiation.c>
  Options -Multiviews
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) Toujours enlever le www (HTTP et HTTPS)
  RewriteCond %{HTTP_HOST} ^www\.tchat-direct\.com$ [NC]
  RewriteRule ^ https://tchat-direct.com%{REQUEST_URI} [L,R=301]

  # 2) Forcer HTTPS sur le domaine nu (sans www)
  RewriteCond %{HTTP_HOST} ^tchat-direct\.com$ [NC]
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://tchat-direct.com%{REQUEST_URI} [L,R=301]

  # 3) Ne pas réécrire si la cible est déjà un fichier ou un dossier
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 4) /p/123-titre -> project.php?id=123
  RewriteRule ^p/([0-9]+)-?([A-Za-z0-9-]*)$ project.php?id=$1 [QSA,L]

  # 5) /tag/xxx -> index.php?tag=xxx
  RewriteRule ^tag/([A-Za-z0-9-]+)$ index.php?tag=$1 [QSA,L]

</IfModule>

  
# ============================
# Cache navigateur (PageSpeed)
# ============================

<IfModule mod_expires.c>
  ExpiresActive On

  # Images
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff  "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # CSS / JS
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType text/javascript "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
  # Cache long pour les fichiers versionnés/statiques
  <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|css|js|woff2|woff)$">  
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
# ============================
